<?xml version="1.0" encoding="UTF-8" ?>
<!-- Fast-DDS transport profile for Dyno.
     - Disables shared memory: root/user process boundary causes silent drops.
     - Restricts UDP to loopback (127.0.0.1): prevents DDS multicast discovery
       from leaking to other machines on the same WiFi/LAN.
     All Dyno ROS2 processes (bridge_ros2, dyno_gui, dyno_plot) run on the same
     machine, so loopback-only is sufficient and eliminates cross-machine talk. -->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_localhost</transport_id>
      <type>UDPv4</type>
      <interfaceWhiteList>
        <address>127.0.0.1</address>
      </interfaceWhiteList>
    </transport_descriptor>
  </transport_descriptors>
  <participant profile_name="default" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_localhost</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
</profiles>
